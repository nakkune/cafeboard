version: '3.8'

services:
  postgres:
    image: postgres:15-alpine
    container_name: cafeboard-db
    environment:
      POSTGRES_USER: cafeboard
      POSTGRES_PASSWORD: cafeboard123
      POSTGRES_DB: cafeboard
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    restart: always
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U cafeboard"]
      interval: 5s
      timeout: 5s
      retries: 5

  backend:
    build:
      context: ./backend
      dockerfile: Dockerfile
    container_name: cafeboard-backend
    env_file:
      - ./backend/.env.docker
    ports:
      - "3001:3001"
    restart: always
    depends_on:
      postgres:
        condition: service_healthy

  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile
      args:
        - VITE_API_URL=/api
    container_name: cafeboard-frontend
    ports:
      - "80:80"
    restart: always
    depends_on:
      - backend

  # ─── Jenkins ──────────────────────────────────────────
  jenkins:
    build:
      context: .
      dockerfile: Dockerfile.jenkins
    container_name: jenkins-local
    privileged: true
    user: root
    network_mode: "host"
    restart: always
    volumes:
      - ./jenkins_home:/var/jenkins_home
      - /var/run/docker.sock:/var/run/docker.sock
    environment:
      - TZ=Asia/Seoul

# ─── 볼륨 ───────────────────────────────────────────────      
volumes:
  postgres_data:
