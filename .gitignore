# [/cafeboard/.gitignore]

# 1. 의존성 (Dependencies)
node_modules/
**/node_modules/

# 2. 빌드 및 결과물 (Build Outputs)
dist/
**/dist/
build/
.next/
out/

# 3. 환경 변수 및 비밀키 (Environment / Secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.docker
*.local
!.env.example

# 4. 로그 및 임시 파일 (Logs and Tasks)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
.pnpm-debug.log*
.agent/
.temp/
tmp/

# 5. OS 및 에디터 설정 (OS / IDE)
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 6. 업로드 데이터 (Runtime Uploads)
backend/uploads/
frontend/uploads/
**/uploads/*
!**/uploads/.gitkeep

# 7. Prisma 및 DB 관련
/backend/prisma/*.db
/backend/prisma/*.db-journal
